# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook — Dashboard → Developers → Webhooks → Add endpoint
# URL: https://YOUR-DOMAIN.vercel.app/api/webhook
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Custom domain + Zoho email
NEXT_PUBLIC_APP_URL=https://getrestwellbaby.mom
NEXT_PUBLIC_EMAIL_DOMAIN=getrestwellbaby.mom
NEXT_PUBLIC_CONTACT_EMAIL=hello@getrestwellbaby.mom

# Purchase log admin page at /admin
ADMIN_PASSWORD=choose-a-strong-password

# Optional — Vercel → Storage → Blob → connect store → copy token
# Enables persistent purchase logs from webhook (recommended)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...